<?xml version="1.0"?>
<ruleset name="Project">

    <!-- DisallowMixedTypeHint excluded: this package decrypts and caches
         arbitrary user-encrypted values, so the decrypted value, the cache
         envelope, config defaults, and metric context are genuinely `mixed`
         and cannot be narrowed. PHPStan (level 8 + strict rules) still guards
         every unsafe mixed access. -->
    <rule ref="SineMaculaLaravelPackage">
        <exclude name="SlevomatCodingStandard.TypeHints.DisallowMixedTypeHint"/>
    </rule>

    <file>src</file>
    <file>tests</file>

</ruleset>
